{
  "ConnectionStrings": {
    "Default": "Server=localhost;Database=SimplerJiangAiAgent;Trusted_Connection=True;TrustServerCertificate=True;Encrypt=False;MultipleActiveResultSets=True"
  },
  "Database": {
    "Provider": "SqlServer",
    "ConnectionString": ""
  },
  "StockCrawler": {
    "EnableAntiCrawlStub": false,
    "EnableProxyPoolStub": false,
    "HttpTimeoutSeconds": 20
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "SourceGovernance": {
    "IntervalSeconds": 86400,
    "MaxConsecutiveFailures": 3,
    "MinParseSuccessRate": 0.85,
    "MinTimestampCoverage": 0.9,
    "MaxFreshnessLagMinutes": 240,
    "CandidatePromotionScore": 0.8,
    "EnableLlmDiscovery": true,
    "EnableCrawlerAutoFix": true,
    "LlmProvider": "active",
    "LlmModel": "",
    "MaxDailyDiscoveryCandidates": 10,
    "HttpTimeoutSeconds": 20
  }
}
